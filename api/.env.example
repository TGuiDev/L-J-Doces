## ============================================
## SUPABASE - Banco de dados e autenticação
## ============================================
## Obter em: https://app.supabase.com
## 1. Crie um projeto
## 2. Vá em Settings → API → URLs e Keys
## 3. Copie os valores abaixo

SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

## ============================================
## JWT - Autenticação da API
## ============================================
## JWT_SECRET: Use uma chave segura e aleatória
## Gerar em: https://www.uuidgenerator.net/
## Ou: openssl rand -base64 32

JWT_SECRET=
JWT_EXPIRATION=7d

## ============================================
## GOOGLE OAUTH - Login com Google
## ============================================
## Obter em: https://console.cloud.google.com
## 1. Crie um novo projeto
## 2. Vá em Credentials → Create Credential → OAuth 2.0 Client ID
## 3. Selecione "Web Application"
## 4. Copie Client ID e Client Secret
## 5. Configure Authorized redirect URIs:
##    - http://localhost:3000/auth/google/callback
##
## IMPORTANTE: Adicione no Supabase:
## Settings → Authentication → Providers → Google → Enable
## Cole as credenciais do Google

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:3000/auth/google/callback

## ============================================
## OPENAI - Análise com IA
## ============================================
## Obter em: https://platform.openai.com/api-keys
## 1. Faça login na sua conta OpenAI
## 2. Vá em API Keys
## 3. Clique em "Create new secret key"
## 4. Copie a chave gerada (salve em local seguro!)
## 5. Cole aqui
##
## IMPORTANTE:
## - Nunca compartilhe esta chave
## - Monitore o uso para evitar custos altos
## - Recomendado: GPT-4 para análises melhores

OPENAI_API_KEY=sk-proj-sua-chave-aqui

## ============================================
## AMBIENTE
## ============================================
NODE_ENV=development
API_PORT=3000
