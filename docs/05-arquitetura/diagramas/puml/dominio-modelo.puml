@startuml
title L&J Doces - Diagrama de Dominio

skinparam shadowing false
skinparam defaultFontName Arial
skinparam backgroundColor #FCFCFA
skinparam class {
  BackgroundColor #FFF8E8
  BorderColor #8D5A00
  ArrowColor #555555
}
skinparam stereotypeCBackgroundColor #EAF3FF
skinparam stereotypeCBorderColor #4B78A8
hide empty methods

class Usuario {
  +id: UUID
  +nome: string
  +email: string
  +papel: PapelUsuario
  +ativo: bool
}

class Perfil {
  +telefone: string
  +fotoUrl: string
  +ultimaAtualizacao: datetime
}

class Produto {
  +id: UUID
  +name: string
  +description: text
  +ingredients: text
  +images: jsonb
  +available_days: jsonb
  +stock_quantity: int
  +price: numeric
  +cost_price: numeric
  +created_at: datetime
}

class Categoria {
  +id: UUID
  +name: string
  +description: text
  +image_url: text
  +order_index: int
  +created_at: datetime
}

class Subcategoria {
  +id: UUID
  +category_id: UUID
  +name: string
  +description: text
  +image_url: text
  +order_index: int
  +created_at: datetime
}

class Pedido {
  +id: UUID
  +user_id: UUID
  +status: StatusPedido
  +total_amount: numeric
  +stock_deducted_at: datetime
  +created_at: datetime
  +updated_at: datetime
}

class ItemPedido {
  +id: UUID
  +order_id: UUID
  +product_id: UUID
  +quantity: int
  +unit_price: numeric
  +observation: text
  +created_at: datetime
}

class Favorito {
  +id: UUID
  +user_id: UUID
  +product_id: UUID
  +created_at: datetime
}

class Banner {
  +id: UUID
  +title: text
  +image_url: text
  +ativo: bool
  +order_index: int
  +created_at: datetime
}

class Payment {
  +id: UUID
  +order_id: UUID
  +amount: numeric
  +status: text
  +payment_method: text
  +transaction_id: text
  +receipt_number: text
  +paid_at: datetime
  +created_at: datetime
  +updated_at: datetime
}

class OrderTracking {
  +id: UUID
  +order_id: UUID
  +status: text
  +message: text
  +created_at: datetime
}

class StockMovement {
  +id: UUID
  +order_id: UUID
  +product_id: UUID
  +movement_type: text
  +quantity: int
  +stock_before: int
  +stock_after: int
  +reason: text
  +created_at: datetime
}

class DailySalesSnapshot {
  +id: UUID
  +snapshot_date: date
  +total_orders: int
  +total_revenue: numeric
  +total_cost: numeric
  +total_profit: numeric
  +completed_payments: int
  +average_ticket: numeric
  +created_at: datetime
  +updated_at: datetime
}

enum StatusPedido {
  pending
  received
  em_preparo
  pronto
  entregue
  cancelado
}

enum PapelUsuario {
  cliente
  administrador
}

enum TipoMovimento {
  entrada
  saida
  ajuste
}

enum TipoVenda {
  imediata
  penduricalho
}

Usuario "1" -- "1" Perfil : possui >
Usuario "1" -- "0..*" Pedido : cria >
Pedido "1" -- "1..*" ItemPedido : contem >
ItemPedido "*" -- "1" Produto : referencia >
Produto "*" -- "1" Categoria : pertence >
Produto "*" -- "0..1" Subcategoria : pertence >
Usuario "1" -- "0..*" Favorito : marca >
Favorito "*" -- "1" Produto : aponta >

Pedido "1" -- "0..*" Payment : possui >
Pedido "1" -- "0..*" OrderTracking : rastreia >
Pedido "1" -- "0..*" StockMovement : gera >
Produto "1" -- "0..*" StockMovement : sofre >

Categoria "1" -- "0..*" Subcategoria : agrega >

Banner ..> Produto : destaca
Pedido ..> StatusPedido
Usuario ..> PapelUsuario
StockMovement ..> TipoMovimento
Payment ..> TipoVenda

note right of Pedido
RN-14: Integridade do pedido
RN-15: Status sincronizado em tempo real
end note

note right of Produto
RN-01: sem estoque => indisponivel
RN-02: alerta por estoque minimo
end note

@enduml
